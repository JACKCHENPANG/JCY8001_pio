page { background: #f2f2f7; font-family: -apple-system, "PingFang SC", sans-serif; color: #1c1c1e; }
.card { background: #fff; border-radius: 16rpx; padding: 24rpx; margin: 20rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.btn-primary { background: #0071e3; color: #fff; border-radius: 12rpx; }
.btn-primary[disabled] { background: #b0c8e8; color: #eef; }
.row { display: flex; justify-content: space-between; align-items: center; padding: 10rpx 0; }
.lbl { color: #8e8e93; font-size: 26rpx; }
.val { font-size: 30rpx; font-weight: 600; }
.title { font-size: 30rpx; font-weight: 700; margin-bottom: 10rpx; }
.bad { color: #ff3b30; }
.ok { color: #34c759; }
